# ====================================================================
# Hermes Agent Profile - 個人跨裝置同步專用 GitIgnore
# ====================================================================

# Credentials & secrets — NEVER commit
auth.json
.env
.env.EXAMPLE    # generated by install, not authorship domain
*.pem
*.key

# Runtime databases & state
state.db
state.db-shm
state.db-wal
hermes_state.db
response_store.db
response_store.db-shm
response_store.db-wal
gateway.pid
gateway_state.json
processes.json
auth.lock
active_profile
.update_check
*.db
*.sqlite
*.sqlite3

# User data — NEVER commit
memories/
sessions/
logs/
*.log
plans/
workspace/
home/

# Caches & generated artifacts
image_cache/
audio_cache/
document_cache/
browser_screenshots/
cache/
pastes/
*-snapshots/
.skills_prompt_snapshot.json
# temporary files
*_cache.*
*.imported
*.bak.*
*.patch
*.tmp

# Cron task runtime artifacts (keep jobs.json configuration)
cron/output/
cron/.tick.lock*

# Skills directory - exclude generated metadata (keep skill definitions)
skills/.bundled_manifest*
skills/.curator_backups/
skills/.curator_state*
skills/.usage.json*
skills/.hub/

# Infrastructure (should not be in profile dir, but safe to exclude)
hermes-agent/
.worktrees/
profiles/
bin/
node_modules/

# ====================================================================
# 以下檔案/目錄應該被 git 追蹤（不在上述排除清單中）：
# ====================================================================
# ✅ cron/jobs.json         — 定時任務配置
# ✅ skills/*/SKILL.md      — 技能定義
# ✅ skills/*/scripts/      — 技能脚本
# ✅ skills/*/references/   — 技能參考資料
# ✅ skills/*/templates/    — 技能樣板
# ✅ scripts/               — 自訂腳本
# ✅ config.yaml            — 主配置檔案
# ✅ SOUL.md                — Agent 靈魂檔案

# User customization namespace — your local overrides
local/

# Checkpoints & backups (can be huge)
checkpoints/
sandboxes/
backups/

# Logs
errors.log
.hermes_history

#
__pycache__/
*.py[cod]
.DS_Store
Thumbs.db
.vscode/
.idea/
